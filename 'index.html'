<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover"/>
  <meta name="theme-color" content="#0C0D0C"/>
  <meta property="og:title"       content="Hiple | 당신만의 아지트 탐험 나침반"/>
  <meta property="og:description" content="광고 없는 진짜 로컬. 한남·연남동의 숨겨진 공간을 발견하세요."/>
  <title>Hiple — 당신만의 아지트 탐험 나침반</title>

  <link rel="preconnect" href="https://fonts.googleapis.com"/>
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin/>
  <link href="https://fonts.googleapis.com/css2?family=Space+Mono:wght@400;700&display=swap" rel="stylesheet"/>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/gh/orioncactus/pretendard@v1.3.9/dist/web/variable/pretendardvariable.min.css"/>

  <style>
    @font-face {
      font-family: 'Clash Display';
      src: url('https://cdn.jsdelivr.net/npm/@fontsource/clash-display@5.0.2/files/clash-display-all-600-normal.woff2') format('woff2');
      font-weight: 600; font-display: swap;
    }
    @font-face {
      font-family: 'Clash Display';
      src: url('https://cdn.jsdelivr.net/npm/@fontsource/clash-display@5.0.2/files/clash-display-all-700-normal.woff2') format('woff2');
      font-weight: 700; font-display: swap;
    }
  </style>

  <style>
    /* ═══════════════════════════════════
       TOKENS
    ═══════════════════════════════════ */
    :root {
      --bg:       #0C0D0C;
      --s1:       #111311;
      --s2:       #181A18;
      --s3:       #1E221E;
      --border:   #242824;
      --borderHi: #384038;
      --gold:     #C9A84C;
      --goldSoft: rgba(201,168,76,0.10);
      --goldLine: rgba(201,168,76,0.28);
      --goldGlow: rgba(201,168,76,0.14);
      --white:    #F0F2F0;
      --offwhite: #D8DDD8;
      --gray:     #8A9A8A;
      --dim:      #4A5A4A;
      --moss:     #6B9E72;
      --clash: 'Clash Display','Pretendard Variable',sans-serif;
      --body:  'Pretendard Variable','Pretendard',-apple-system,sans-serif;
      --mono:  'Space Mono','Courier New',monospace;
      --ease:   cubic-bezier(0.22,1,0.36,1);
      --spring: cubic-bezier(0.32,0.72,0,1);

      /* ── 반응형 섹션 패딩 토큰 ── */
      --sec-py: 120px;
      --wrap-px: 48px;
    }
    @media (max-width: 768px) {
      :root {
        --sec-py:  72px;
        --wrap-px: 20px;
      }
    }
    @media (max-width: 480px) {
      :root {
        --sec-py:  56px;
        --wrap-px: 16px;
      }
    }

    /* ═══════════════════════════════════
       RESET & BASE
    ═══════════════════════════════════ */
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html {
      scroll-behavior: smooth;
      /* 가로 스크롤 원천 차단 */
      overflow-x: hidden;
      max-width: 100vw;
    }
    body {
      background: var(--bg);
      color: var(--white);
      font-family: var(--body);
      overflow-x: hidden;
      max-width: 100vw;
      -webkit-font-smoothing: antialiased;
      -moz-osx-font-smoothing: grayscale;
      -webkit-text-size-adjust: 100%;
    }
    img, video, svg { max-width: 100%; display: block; }
    a { color: inherit; text-decoration: none; }
    ::selection { background: var(--goldSoft); color: var(--gold); }
    ::-webkit-scrollbar { width: 3px; }
    ::-webkit-scrollbar-track { background: transparent; }
    ::-webkit-scrollbar-thumb { background: var(--border); border-radius: 999px; }

    /* ═══════════════════════════════════
       NOISE (GPU-composited — no repaint)
    ═══════════════════════════════════ */
    body::before {
      content: '';
      position: fixed; inset: 0;
      pointer-events: none; z-index: 9999;
      opacity: 0.025;
      will-change: opacity; /* GPU layer 격리 */
      background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
      background-size: 160px;
    }
    /* 모바일: 노이즈 비활성화 (성능 절약) */
    @media (max-width: 768px) { body::before { display: none; } }

    /* ═══════════════════════════════════
       SCROLL REVEAL
    ═══════════════════════════════════ */
    .reveal {
      opacity: 0;
      transform: translateY(18px);
      transition: opacity 0.65s var(--ease), transform 0.65s var(--ease);
    }
    .reveal.up { opacity: 1; transform: none; }
    /* 모바일: 지연 제거 (터치 즉시성) */
    .d1 { transition-delay: 0.07s; }
    .d2 { transition-delay: 0.14s; }
    .d3 { transition-delay: 0.21s; }
    .d4 { transition-delay: 0.28s; }
    @media (max-width: 768px) { .d1,.d2,.d3,.d4 { transition-delay: 0s; } }

    /* ═══════════════════════════════════
       LAYOUT
    ═══════════════════════════════════ */
    .wrap {
      width: 100%; max-width: 1280px;
      margin: 0 auto;
      padding: 0 var(--wrap-px);
    }
    section { padding: var(--sec-py) 0; }

    /* ═══════════════════════════════════
       NAV
    ═══════════════════════════════════ */
    nav {
      position: fixed; top: 0; left: 0; right: 0;
      z-index: 200;
      padding: 16px 0;
      transition: background 0.5s, border-bottom 0.5s;
    }
    nav.stuck {
      background: rgba(12,13,12,0.9);
      backdrop-filter: blur(20px);
      -webkit-backdrop-filter: blur(20px);
      border-bottom: 1px solid var(--border);
    }
    .nav-row {
      display: flex; align-items: center;
      justify-content: space-between; gap: 16px;
    }
    .nav-logo {
      font-family: var(--clash);
      font-size: 1.25rem; font-weight: 700;
      color: var(--gold); letter-spacing: 0.02em;
      flex-shrink: 0;
    }
    .nav-links {
      display: flex; align-items: center; gap: 28px; list-style: none;
    }
    .nav-links a {
      font-size: 0.75rem; font-weight: 500;
      letter-spacing: 0.08em; text-transform: uppercase;
      color: var(--dim); transition: color 0.2s;
    }
    .nav-links a:hover { color: var(--white); }
    /* 터치 친화적 nav CTA: min 48px */
    .nav-pill {
      display: inline-flex; align-items: center; justify-content: center;
      min-height: 44px;
      padding: 0 20px;
      background: var(--gold); color: #090B09;
      font-family: var(--clash); font-size: 0.75rem; font-weight: 700;
      border-radius: 999px; letter-spacing: 0.04em;
      transition: transform 0.15s var(--spring), opacity 0.2s;
      white-space: nowrap; flex-shrink: 0;
    }
    .nav-pill:hover { transform: scale(1.03); opacity: 0.9; }
    /* 860px 이하: 링크 숨김 */
    @media (max-width: 860px) { .nav-links { display: none; } }

    /* ═══════════════════════════════════
       버튼 공통 — 최소 48px 터치 영역
    ═══════════════════════════════════ */
    .btn-primary, .btn-ghost {
      display: inline-flex; align-items: center; justify-content: center;
      gap: 8px;
      min-height: 52px;
      border-radius: 6px;
      font-weight: 600; letter-spacing: 0.02em;
      cursor: pointer; border: none;
      -webkit-tap-highlight-color: transparent;
      touch-action: manipulation;
      transition: transform 0.15s var(--spring), box-shadow 0.25s, opacity 0.2s;
    }
    .btn-primary {
      padding: 0 28px;
      background: var(--gold); color: #090B09;
      font-family: var(--clash); font-size: 0.9rem; font-weight: 700;
    }
    .btn-primary:hover {
      transform: translateY(-2px);
      box-shadow: 0 12px 36px rgba(201,168,76,0.25);
      opacity: 0.92;
    }
    .btn-primary:active { transform: scale(0.97); }
    .btn-ghost {
      padding: 0 24px;
      border: 1px solid var(--border) !important;
      background: transparent; color: var(--gray);
      font-size: 0.875rem;
    }
    .btn-ghost:hover { border-color: var(--borderHi) !important; color: var(--white); }
    .btn-ghost:active { transform: scale(0.97); }

    /* 모바일: 버튼 풀 폭 */
    @media (max-width: 480px) {
      .btn-primary, .btn-ghost {
        width: 100%;
        min-height: 56px;
        font-size: 1rem;
        justify-content: center;
      }
    }

    /* ═══════════════════════════════════
       HERO
    ═══════════════════════════════════ */
    .hero {
      min-height: 100svh;
      display: flex; flex-direction: column;
      justify-content: center; align-items: flex-start;
      padding: 100px 0 72px;
      position: relative; overflow: hidden;
    }
    .hero-grid {
      position: absolute; inset: 0; pointer-events: none;
      background-image: radial-gradient(circle, var(--border) 1px, transparent 1px);
      background-size: 40px 40px;
      opacity: 0.5;
      mask-image: radial-gradient(ellipse 90% 90% at 50% 50%, black 20%, transparent 75%);
    }
    @media (max-width: 768px) {
      .hero-grid { background-size: 32px 32px; opacity: 0.35; }
    }
    .hero-blob {
      position: absolute; top: 20%; right: -20%;
      width: min(600px, 100vw); height: min(600px, 100vw);
      background: radial-gradient(circle, rgba(201,168,76,0.05) 0%, transparent 65%);
      pointer-events: none;
    }
    .hero-tag {
      display: inline-flex; align-items: center; gap: 8px;
      font-family: var(--mono);
      font-size: clamp(0.6rem, 2.5vw, 0.7rem);
      color: var(--gold);
      border: 1px solid var(--goldLine);
      background: var(--goldSoft);
      border-radius: 4px; padding: 6px 12px;
      margin-bottom: 28px;
      position: relative; z-index: 1;
      animation: fadeUp 0.7s var(--ease) 0.1s both;
      letter-spacing: 0.08em; white-space: nowrap;
    }
    .hero-tag-dot {
      width: 5px; height: 5px; border-radius: 50%;
      background: var(--gold); flex-shrink: 0;
      animation: blink 2s ease-in-out infinite;
    }
    @keyframes blink { 0%,100%{opacity:1} 50%{opacity:0.3} }

    /* ── Hero 타이틀: clamp 범위를 모바일~데스크탑 전 구간 커버 ── */
    .hero-h1 {
      font-family: var(--clash);
      /* min: 44px(극소형), preferred: 11vw, max: 140px */
      font-size: clamp(2.75rem, 11vw, 8.75rem);
      font-weight: 700;
      line-height: 0.94;
      letter-spacing: -0.03em;
      color: var(--white);
      position: relative; z-index: 1;
      animation: fadeUp 0.8s var(--ease) 0.2s both;
      /* 텍스트 잘림 방지 */
      word-break: keep-all;
      overflow-wrap: break-word;
    }
    .hero-h1 .gold { color: var(--gold); }
    .hero-h1 .stroke {
      -webkit-text-stroke: 1.5px var(--borderHi); color: transparent;
    }
    .hero-h1 .stroke.gold-stroke { -webkit-text-stroke-color: rgba(201,168,76,0.45); }
    /* 모바일: stroke 두께 조정 */
    @media (max-width: 480px) {
      .hero-h1 .stroke { -webkit-text-stroke-width: 1px; }
    }

    .hero-row {
      display: flex; align-items: flex-end;
      gap: 32px; flex-wrap: wrap;
      margin-top: 36px;
      position: relative; z-index: 1;
      animation: fadeUp 0.8s var(--ease) 0.45s both;
    }
    /* 모바일: 세로 스택 */
    @media (max-width: 640px) {
      .hero-row { flex-direction: column; align-items: flex-start; gap: 24px; }
    }
    .hero-desc {
      font-size: clamp(0.875rem, 2.5vw, 1rem);
      font-weight: 400; color: var(--gray);
      line-height: 1.75; max-width: 380px;
    }
    .hero-desc strong { color: var(--offwhite); font-weight: 500; }
    .hero-btns {
      display: flex; gap: 10px; flex-wrap: wrap; flex-shrink: 0;
    }
    @media (max-width: 480px) {
      .hero-btns { width: 100%; flex-direction: column; }
    }

    .hero-scroll {
      position: absolute; bottom: 28px; left: 0; right: 0;
      display: flex; justify-content: center; z-index: 1;
      animation: fadeUp 0.8s var(--ease) 1.2s both;
    }
    /* 작은 화면에서 scroll mouse 숨김 */
    @media (max-width: 480px) { .hero-scroll { display: none; } }
    .scroll-mouse {
      width: 20px; height: 32px;
      border: 1.5px solid var(--borderHi); border-radius: 10px;
      position: relative;
    }
    .scroll-mouse::before {
      content: '';
      width: 2px; height: 5px; background: var(--gold);
      border-radius: 1px;
      position: absolute; top: 5px; left: 50%;
      transform: translateX(-50%);
      animation: scrollWheel 1.8s ease-in-out infinite;
    }
    @keyframes scrollWheel {
      0%   { opacity: 1; transform: translateX(-50%) translateY(0); }
      100% { opacity: 0; transform: translateX(-50%) translateY(9px); }
    }

    /* ═══════════════════════════════════
       TICKER
    ═══════════════════════════════════ */
    .ticker-wrap {
      border-top: 1px solid var(--border); border-bottom: 1px solid var(--border);
      padding: 12px 0; overflow: hidden; background: var(--s1);
    }
    .ticker {
      display: flex; gap: 0;
      animation: ticker 30s linear infinite;
      white-space: nowrap; will-change: transform;
    }
    /* 모바일: hover pause 제거 (터치 무관) */
    @media (hover: hover) { .ticker:hover { animation-play-state: paused; } }
    .t-item {
      display: inline-flex; align-items: center; gap: 14px;
      padding: 0 28px;
      font-family: var(--mono);
      font-size: clamp(0.55rem, 1.8vw, 0.625rem);
      letter-spacing: 0.12em; text-transform: uppercase; color: var(--dim);
    }
    .t-item em { color: var(--gold); font-style: normal; }
    .t-sep { width: 2px; height: 2px; border-radius: 50%; background: var(--border); flex-shrink: 0; }
    @keyframes ticker { 0%{transform:translateX(0)} 100%{transform:translateX(-50%)} }

    /* ═══════════════════════════════════
       SECTION 공통 타이포
    ═══════════════════════════════════ */
    .section-eyebrow {
      display: inline-flex; align-items: center; gap: 10px;
      font-family: var(--mono);
      font-size: clamp(0.6rem, 2vw, 0.625rem);
      letter-spacing: 0.14em; text-transform: uppercase;
      color: var(--gold); margin-bottom: 20px;
    }
    .eyebrow-line { width: 28px; height: 1px; background: var(--gold); flex-shrink: 0; }

    .section-h {
      font-family: var(--clash);
      /* 모바일 min: 2rem, max: 4.5rem */
      font-size: clamp(2rem, 5.5vw, 4.5rem);
      font-weight: 700; line-height: 1.0;
      letter-spacing: -0.035em; color: var(--white);
      margin-bottom: 16px;
      word-break: keep-all;
    }
    .section-h .gold { color: var(--gold); }
    .section-h .stroke { -webkit-text-stroke: 1.5px var(--borderHi); color: transparent; }
    @media (max-width: 480px) { .section-h .stroke { -webkit-text-stroke-width: 1px; } }

    .section-sub {
      font-size: clamp(0.875rem, 2.5vw, 1rem);
      font-weight: 400; color: var(--gray); line-height: 1.75;
      max-width: 500px; word-break: keep-all;
    }

    /* ═══════════════════════════════════
       NUMBERS STRIP
    ═══════════════════════════════════ */
    .numbers-strip {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      border: 1px solid var(--border); border-radius: 12px;
      overflow: hidden; margin-top: 56px; background: var(--s1);
    }
    @media (max-width: 600px) {
      .numbers-strip { grid-template-columns: 1fr 1fr; }
    }
    .num-cell {
      padding: clamp(20px, 4vw, 36px) clamp(16px, 3vw, 32px);
      border-right: 1px solid var(--border);
      transition: background 0.3s;
    }
    .num-cell:last-child { border-right: none; }
    @media (hover: hover) { .num-cell:hover { background: var(--s2); } }
    @media (max-width: 600px) {
      .num-cell:nth-child(2) { border-right: none; }
      .num-cell:nth-child(3) { border-top: 1px solid var(--border); }
      .num-cell:nth-child(4) { border-top: 1px solid var(--border); border-right: none; }
    }
    .num-val {
      font-family: var(--clash);
      font-size: clamp(2.25rem, 7vw, 3.5rem);
      font-weight: 700; line-height: 1; letter-spacing: -0.04em;
      color: var(--gold); display: block; margin-bottom: 6px;
    }
    .num-label {
      font-family: var(--mono);
      font-size: clamp(0.55rem, 1.8vw, 0.625rem);
      letter-spacing: 0.1em; text-transform: uppercase; color: var(--dim);
    }

    /* ═══════════════════════════════════
       HOW GRID
    ═══════════════════════════════════ */
    .how-layout {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 2px; margin-top: 52px;
      border-radius: 12px; overflow: hidden;
      background: var(--border);
    }
    /* 태블릿·모바일: 1열 */
    @media (max-width: 720px) {
      .how-layout { grid-template-columns: 1fr; }
    }
    .how-item {
      background: var(--s1);
      padding: clamp(28px, 5vw, 48px) clamp(24px, 4vw, 44px);
      position: relative; overflow: hidden;
      transition: background 0.3s;
    }
    @media (hover: hover) { .how-item:hover { background: var(--s2); } }
    .how-bar {
      position: absolute; top: 0; left: 0; right: 0; height: 2px;
      background: linear-gradient(90deg, var(--gold), transparent);
      opacity: 0; transition: opacity 0.3s;
    }
    @media (hover: hover) { .how-item:hover .how-bar { opacity: 1; } }
    .how-num {
      font-family: var(--mono);
      font-size: 0.6875rem; letter-spacing: 0.14em;
      color: var(--gold); text-transform: uppercase;
      margin-bottom: 16px; display: block;
    }
    .how-title {
      font-family: var(--clash);
      font-size: clamp(1.1rem, 3vw, 1.625rem);
      font-weight: 700; letter-spacing: -0.03em;
      color: var(--white); margin-bottom: 12px;
    }
    .how-desc {
      font-size: clamp(0.8rem, 2.2vw, 0.875rem);
      font-weight: 400; color: var(--gray); line-height: 1.78;
      word-break: keep-all;
    }

    /* ═══════════════════════════════════
       BENTO GRID
    ═══════════════════════════════════ */
    .bento {
      display: grid;
      grid-template-columns: repeat(12, 1fr);
      gap: 10px; margin-top: 52px;
    }
    /* 태블릿: 2열 */
    @media (max-width: 900px)  { .bento { grid-template-columns: 1fr 1fr; } }
    /* 모바일: 1열 */
    @media (max-width: 560px)  { .bento { grid-template-columns: 1fr; } }

    .bc {
      background: var(--s1); border: 1px solid var(--border);
      border-radius: 12px;
      padding: clamp(20px, 4vw, 32px);
      position: relative; overflow: hidden;
      transition: border-color 0.3s, transform 0.25s var(--spring);
    }
    @media (hover: hover) {
      .bc:hover { border-color: var(--borderHi); transform: translateY(-2px); }
    }
    .c5 { grid-column: span 5; }
    .c7 { grid-column: span 7; }
    .c6 { grid-column: span 6; }
    /* 태블릿·모바일: span 1 */
    @media (max-width: 900px) { .c5,.c7,.c6 { grid-column: span 1; } }

    /* mouse glow: 데스크탑 only */
    @media (hover: hover) {
      .bc::after {
        content: ''; position: absolute; inset: 0;
        background: radial-gradient(circle at var(--mx,50%) var(--my,50%), var(--goldSoft), transparent 55%);
        opacity: 0; transition: opacity 0.4s; pointer-events: none;
      }
      .bc:hover::after { opacity: 1; }
    }
    .bc-label {
      font-family: var(--mono);
      font-size: 0.6rem; letter-spacing: 0.12em; text-transform: uppercase;
      color: var(--gold); border: 1px solid var(--goldLine);
      background: var(--goldSoft); border-radius: 3px; padding: 3px 8px;
      display: inline-block; margin-bottom: 14px;
    }
    .bc-title {
      font-family: var(--clash);
      font-size: clamp(1rem, 2.5vw, 1.375rem);
      font-weight: 700; letter-spacing: -0.03em;
      color: var(--white); margin-bottom: 8px;
    }
    .bc-desc {
      font-size: clamp(0.8rem, 2vw, 0.8125rem);
      color: var(--gray); line-height: 1.75; word-break: keep-all;
    }

    /* 나침반 */
    .compass-ring-wrap {
      width: min(160px, 70%); aspect-ratio: 1;
      margin: 24px auto 0;
      position: relative;
      display: flex; align-items: center; justify-content: center;
    }
    .c-ring {
      position: absolute; border-radius: 50%;
      border: 1px solid var(--goldLine);
    }
    .cr1 { width:90%;height:90%; animation:rot 12s linear infinite; border-style:dashed; border-color:rgba(201,168,76,0.2); }
    .cr2 { width:64%;height:64%; animation:rot 7s linear infinite reverse; }
    .cr3 { width:40%;height:40%; opacity:0.3; }
    .c-glyph { font-size: clamp(2rem, 8vw, 2.75rem); position:relative;z-index:1; animation:rot 3.5s linear infinite; filter:drop-shadow(0 0 8px rgba(201,168,76,0.3)); }

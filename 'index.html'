    .cta-sub {
      font-size: clamp(0.875rem, 2.5vw, 1rem);
      font-weight: 400; color: var(--gray); margin-bottom: 36px;
      position: relative; z-index: 1; word-break: keep-all;
    }
    .cta-btns {
      display: flex; align-items: center; justify-content: center;
      gap: 12px; flex-wrap: wrap; position: relative; z-index: 1;
    }
    @media (max-width: 480px) {
      .cta-btns { flex-direction: column; align-items: stretch; }
    }
    .cta-note {
      margin-top: 20px; font-family: var(--mono);
      font-size: 0.5625rem; letter-spacing: 0.08em; color: var(--dim);
      position: relative; z-index: 1;
    }


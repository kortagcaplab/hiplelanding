    ═══════════════════════════════════ */
    .founder-strip {
      border-top: 1px solid var(--border);
      padding: 28px 0;
      background: var(--bg);
    }
    .founder-inner {
      display: flex; align-items: center; gap: 16px;
      flex-wrap: wrap;
    }
    .founder-line {
      width: 20px; height: 1px;
      background: var(--dim); flex-shrink: 0;

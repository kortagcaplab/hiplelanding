    .p-chip.on { border-color: var(--goldLine); background: rgba(201,168,76,0.05); }
    .p-em { font-size: 1.125rem; flex-shrink: 0; }
    .p-name { font-family: var(--clash); font-size: 0.8125rem; font-weight: 600; color: var(--white); letter-spacing: -0.02em; }
    .p-sub  { font-family: var(--mono); font-size: 0.625rem; color: var(--dim); margin-top: 2px; letter-spacing: 0.04em; }
    .p-active-dot { margin-left: auto; width: 6px; height: 6px; border-radius: 50%; background: var(--gold); flex-shrink: 0; }

    /* Place rows */
    .place-rows { margin-top: 20px; display: flex; flex-direction: column; gap: 8px; }
    .p-row {
      display: flex; align-items: center; gap: 12px;
      background: var(--s2); border: 1px solid var(--border);
      border-radius: 8px; padding: 12px 14px; min-height: 48px;
    }
    .p-rank {
      width: 28px; height: 28px; border-radius: 5px;
      background: var(--goldSoft); border: 1px solid var(--goldLine);
      display: flex; align-items: center; justify-content: center;
      font-family: var(--mono); font-size: 0.6875rem; font-weight: 700;
      color: var(--gold); flex-shrink: 0;
    }
    .p-info { flex: 1; min-width: 0; }
    .p-pname { font-family: var(--clash); font-size: 0.8125rem; font-weight: 600; color: var(--white); letter-spacing: -0.02em; }
    .p-pmeta { font-size: 0.6875rem; color: var(--dim); margin-top: 2px; }
    .p-score { font-family: var(--mono); font-size: 1.25rem; font-weight: 700; color: var(--gold); flex-shrink: 0; }

    /* Privacy rows */
    .priv-rows { margin-top: 20px; display: flex; flex-direction: column; gap: 7px; }
    .priv-row {
      display: flex; align-items: center; gap: 10px;
      background: var(--s2); border: 1px solid var(--border);
      border-radius: 8px; padding: 10px 14px; min-height: 48px;
      font-size: 0.8125rem; color: var(--gray);
    }
    .priv-icon { font-size: 1rem; flex-shrink: 0; }
    .priv-badge {
      margin-left: auto;
      font-family: var(--mono);
      font-size: 0.5625rem; font-weight: 700; letter-spacing: 0.08em; text-transform: uppercase;
      padding: 3px 8px; border-radius: 3px; flex-shrink: 0; white-space: nowrap;
    }
    .priv-badge.ok  { color: var(--moss); background: rgba(107,158,114,0.08); border: 1px solid rgba(107,158,114,0.22); }
    .priv-badge.no  { color: #B85A45; background: rgba(184,90,69,0.08); border: 1px solid rgba(184,90,69,0.22); }

    /* ═══════════════════════════════════
       MANIFESTO
    ═══════════════════════════════════ */
    .manifesto { background: var(--s1); border-top: 1px solid var(--border); border-bottom: 1px solid var(--border); }
    .manifesto-aside {
      font-family: var(--mono);
      font-size: 0.6875rem; letter-spacing: 0.1em;
      text-transform: uppercase; color: var(--dim); margin-bottom: 20px;
    }
    .manifesto-text {
      font-family: var(--clash);
      font-size: clamp(1.75rem, 5vw, 4.25rem);
      font-weight: 700; line-height: 1.08;
      letter-spacing: -0.035em; color: var(--white);
      word-break: keep-all;
    }
    .manifesto-text .gold  { color: var(--gold); }
    .manifesto-text .muted { color: var(--dim); }
    .manifesto-sep {
      width: 1px; height: 52px;
      background: linear-gradient(to bottom, var(--border), transparent);
      margin: 36px 0;
    }
    @media (max-width: 480px) { .manifesto-sep { height: 36px; margin: 24px 0; } }

    /* ═══════════════════════════════════
       PLACES GRID
    ═══════════════════════════════════ */
    .places-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 12px; margin-top: 48px;
    }
    /* 태블릿: 2열 */
    @media (max-width: 900px) { .places-grid { grid-template-columns: 1fr 1fr; } }
    /* 모바일: 1열 */
    @media (max-width: 560px) { .places-grid { grid-template-columns: 1fr; } }

    .place-card {
      background: var(--s1); border: 1px solid var(--border);
      border-radius: 12px; padding: clamp(20px, 4vw, 28px);
      position: relative; overflow: hidden;
      transition: border-color 0.3s, transform 0.25s var(--spring);
    }
    @media (hover: hover) { .place-card:hover { border-color: var(--borderHi); transform: translateY(-3px); } }
    .place-card.hot { border-color: var(--goldLine); }
    .place-card.hot::before {
      content: ''; position: absolute; top: 0; left: 0; right: 0; height: 2px;
      background: linear-gradient(90deg, transparent, var(--gold), transparent);
    }
    .area-tag {
      display: inline-flex; align-items: center; gap: 5px;
      font-family: var(--mono); font-size: 0.625rem; letter-spacing: 0.1em;
      text-transform: uppercase; color: var(--moss);
      border: 1px solid rgba(107,158,114,0.25);
      background: rgba(107,158,114,0.07);
      border-radius: 3px; padding: 3px 9px; margin-bottom: 14px;
    }
    .place-name { font-family: var(--clash); font-size: clamp(1.1rem, 3.5vw, 1.375rem); font-weight: 700; letter-spacing: -0.04em; color: var(--white); margin-bottom: 4px; }
    .place-cat  { font-family: var(--mono); font-size: 0.625rem; letter-spacing: 0.08em; text-transform: uppercase; color: var(--dim); margin-bottom: 14px; }
    .place-desc { font-size: 0.8125rem; font-weight: 400; color: var(--gray); line-height: 1.75; margin-bottom: 16px; word-break: keep-all; }
    .place-tip  { font-size: 0.75rem; color: var(--moss); background: rgba(107,158,114,0.07); border: 1px solid rgba(107,158,114,0.18); border-radius: 6px; padding: 9px 12px; line-height: 1.65; }
    .place-tip::before { content: '→ '; }
    .place-bottom { display: flex; align-items: center; gap: 10px; margin-top: 16px; }
    .pb-label { font-family: var(--mono); font-size: 0.5625rem; letter-spacing: 0.1em; text-transform: uppercase; color: var(--dim); flex-shrink: 0; }
    .pb-bar   { flex: 1; height: 2px; background: var(--s3); border-radius: 999px; overflow: hidden; }
    .pb-fill  { height: 100%; background: linear-gradient(90deg, rgba(201,168,76,0.4), var(--gold)); border-radius: 999px; }
    .pb-val   { font-family: var(--mono); font-size: 0.75rem; font-weight: 700; color: var(--gold); flex-shrink: 0; }

    /* ═══════════════════════════════════
       PERSONA GRID
    ═══════════════════════════════════ */
    .persona-grid {
      display: grid;
      grid-template-columns: repeat(5, 1fr);
      gap: 10px; margin-top: 48px;
    }
    @media (max-width: 1000px) { .persona-grid { grid-template-columns: repeat(3, 1fr); } }
    @media (max-width: 560px)  { .persona-grid { grid-template-columns: 1fr 1fr; } }

    .persona-card {
      background: var(--s1); border: 1px solid var(--border);
      border-radius: 12px; padding: clamp(18px, 3.5vw, 24px) clamp(14px, 3vw, 20px);
      text-align: center;
      transition: border-color 0.3s, transform 0.25s var(--spring), background 0.3s;
    }
    @media (hover: hover) {
      .persona-card:hover { border-color: var(--goldLine); background: rgba(201,168,76,0.04); transform: translateY(-4px); }
    }
    .pc-icon {
      width: 48px; height: 48px; border-radius: 12px;
      background: var(--s2); border: 1px solid var(--border);
      display: flex; align-items: center; justify-content: center;
      font-size: 1.375rem; margin: 0 auto 12px;
      transition: border-color 0.3s;
    }
    @media (hover: hover) { .persona-card:hover .pc-icon { border-color: var(--goldLine); } }
    .pc-name { font-family: var(--clash); font-size: 0.8125rem; font-weight: 700; letter-spacing: -0.03em; color: var(--white); margin-bottom: 4px; word-break: keep-all; }
    .pc-en   { font-family: var(--mono); font-size: 0.5625rem; letter-spacing: 0.08em; text-transform: uppercase; color: var(--gold); margin-bottom: 8px; min-height: 0.8rem; }
    .pc-desc { font-size: 0.75rem; color: var(--dim); line-height: 1.6; word-break: keep-all; }

    /* ═══════════════════════════════════
       이메일 구독 섹션 (신규)
    ═══════════════════════════════════ */
    .signup-section {
      border-top: 1px solid var(--border);
      background: var(--bg);
    }
    .signup-box {
      max-width: 580px; margin: 0 auto;
      text-align: center;
    }
    .signup-eyebrow {
      font-family: var(--mono);
      font-size: 0.6rem; letter-spacing: 0.14em; text-transform: uppercase;
      color: var(--gold); margin-bottom: 16px;
    }
    .signup-title {
      font-family: var(--clash);
      font-size: clamp(1.5rem, 4vw, 2.25rem);
      font-weight: 700; letter-spacing: -0.04em;
      color: var(--white); line-height: 1.1;
      margin-bottom: 10px; word-break: keep-all;
    }
    .signup-title .gold { color: var(--gold); }
    .signup-desc {
      font-size: clamp(0.8125rem, 2.5vw, 0.9375rem);
      color: var(--gray); line-height: 1.75;
      margin-bottom: 32px; word-break: keep-all;
    }
    .signup-form {
      display: flex; gap: 8px;
      background: var(--s1);
      border: 1px solid var(--border);
      border-radius: 10px; padding: 6px 6px 6px 16px;
      transition: border-color 0.3s;
      max-width: 480px; margin: 0 auto;
    }
    .signup-form:focus-within { border-color: var(--goldLine); }
    @media (max-width: 480px) {
      .signup-form { flex-direction: column; padding: 10px; gap: 10px; }
    }
    .signup-input {
      flex: 1; min-width: 0;
      background: transparent; border: none; outline: none;
      font-family: var(--body); font-size: 0.875rem;
      color: var(--white); caret-color: var(--gold);
      padding: 8px 0;
      -webkit-tap-highlight-color: transparent;
    }
    .signup-input::placeholder { color: var(--dim); }
    .signup-input:-webkit-autofill {
      -webkit-box-shadow: 0 0 0 1000px var(--s1) inset;
      -webkit-text-fill-color: var(--white);
    }
    .signup-btn {
      display: inline-flex; align-items: center; justify-content: center;
      gap: 6px; min-height: 44px; padding: 0 20px;
      background: var(--gold); color: #090B09;
      font-family: var(--clash); font-size: 0.8125rem; font-weight: 700;
      border: none; border-radius: 7px; cursor: pointer;
      transition: opacity 0.2s, transform 0.15s var(--spring);
      white-space: nowrap; flex-shrink: 0;
      -webkit-tap-highlight-color: transparent;
      touch-action: manipulation;
    }
    .signup-btn:hover { opacity: 0.9; }
    .signup-btn:active { transform: scale(0.96); }
    @media (max-width: 480px) {
      .signup-btn { width: 100%; min-height: 52px; font-size: 0.9375rem; }
    }
    .signup-success {
      display: none;
      align-items: center; justify-content: center; gap: 8px;
      font-family: var(--mono);
      font-size: 0.75rem; letter-spacing: 0.06em;
      color: var(--moss); margin-top: 14px;
    }
    .signup-success.show { display: flex; animation: fadeUp 0.5s var(--ease) both; }
    .signup-note {
      margin-top: 14px; font-family: var(--mono);
      font-size: 0.5625rem; letter-spacing: 0.08em; text-transform: uppercase;
      color: var(--dim);
    }

    /* ═══════════════════════════════════
       CTA
    ═══════════════════════════════════ */

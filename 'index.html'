  <script>
    // ── NAV sticky ──
    const nav = document.getElementById('nav');
    let ticking = false;
    window.addEventListener('scroll', () => {
      if (!ticking) {
        requestAnimationFrame(() => {
          nav.classList.toggle('stuck', window.scrollY > 50);
          ticking = false;
        });
        ticking = true;
      }
    }, { passive: true });

    // ── Scroll reveal (IO) ──
    const io = new IntersectionObserver(entries => {
      entries.forEach(e => {
        if (e.isIntersecting) { e.target.classList.add('up'); io.unobserve(e.target); }
      });
    }, { threshold: 0.08, rootMargin: '0px 0px -24px 0px' });
    document.querySelectorAll('.reveal').forEach(el => io.observe(el));

    // ── Bento mouse glow: 데스크탑 only ──
    if (window.matchMedia('(hover: hover)').matches) {
      document.querySelectorAll('.bc').forEach(card => {
        card.addEventListener('mousemove', e => {
          const r = card.getBoundingClientRect();
          card.style.setProperty('--mx', ((e.clientX - r.left) / r.width * 100).toFixed(1) + '%');
          card.style.setProperty('--my', ((e.clientY - r.top)  / r.height * 100).toFixed(1) + '%');
        }, { passive: true });
      });
    }

// ── Email signup handler (Google Forms 연동 버전) ──
    let submitted = false; // 제출 상태 확인 변수

    function handleSignupSuccess() {
      if (submitted) {
        // 기존 폼 숨기고 성공 메시지 표시
        const form = document.getElementById('signup-form');
        const success = document.getElementById('signup-success');
        
        if (form && success) {
          form.style.display = 'none';
          success.style.display = 'block';
          success.classList.add('up');
        }
      }
    }

    // 기존 handleSignup 함수는 이제 HTML의 onsubmit="submitted=true;"가 대신하므로 삭제해도 무방하지만, 
    // 유효성 검사(이메일 형식 체크)를 위해 아래와 같이 유지하는 것을 추천합니다.
    function handleSignup(e) {
      const input = document.getElementById('email-input');
      const val = input.value.trim();
      const re = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
      
      if (!re.test(val)) {
        e.preventDefault(); // 형식이 틀리면 전송 중단
        input.style.color = '#B85A45';
        input.style.borderColor = 'rgba(184,90,69,0.4)';
        setTimeout(() => { 
          input.style.color = ''; 
          input.style.borderColor = ''; 
        }, 1400);
        submitted = false;
        return false;
      }
      // 형식이 맞으면 true를 반환하여 폼이 전송되도록 함
      submitted = true;
      return true;
    }

    // ── Reveal 애니메이션 설정 (기존 코드 유지) ──
    const io = new IntersectionObserver((entries) => {
      entries.forEach(e => {
        if (e.isIntersecting) { e.target.classList.add('up'); io.unobserve(e.target); }
      });
    }, { threshold: 0.08, rootMargin: '0px 0px -24px 0px' });
    document.querySelectorAll('.reveal').forEach(el => io.observe(el));

    // ── Bento mouse glow (기존 코드 유지) ──
    if (window.matchMedia('(hover: hover)').matches) {
      document.querySelectorAll('.bc').forEach(card => {
        card.addEventListener('mousemove', e => {
          const r = card.getBoundingClientRect();
          card.style.setProperty('--mx', ((e.clientX - r.left) / r.width * 100).toFixed(1) + '%');
          card.style.setProperty('--my', ((e.clientY - r.top)  / r.height * 100).toFixed(1) + '%');
        }, { passive: true });
      });
    }
  </script>
</body>
</html>

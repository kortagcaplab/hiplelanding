      .cr2 { animation-duration: 11s; }
      .c-glyph { animation-duration: 5s; filter: none; }
    }
    @keyframes rot { to { transform: rotate(360deg); } }

    /* Persona chips */
    .p-stack { margin-top: 20px; display: flex; flex-direction: column; gap: 7px; }
    .p-chip {
      display: flex; align-items: center; gap: 12px;
      background: var(--s2); border: 1px solid var(--border);
      border-radius: 8px; padding: 11px 14px; min-height: 48px;

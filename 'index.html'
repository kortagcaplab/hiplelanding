    .founder-text {
      font-family: var(--mono);
      font-size: 0.5625rem; letter-spacing: 0.08em;
      text-transform: uppercase; color: var(--dim);
      line-height: 1.7;
    }
    .founder-text em { color: var(--gray); font-style: normal; }

    /* ═══════════════════════════════════
       FOOTER
    ═══════════════════════════════════ */
    footer { padding: 36px 0 28px; border-top: 1px solid var(--border); }
    .footer-row {
      display: flex; align-items: center; justify-content: space-between;
      gap: 20px; flex-wrap: wrap;
    }
    @media (max-width: 600px) {
      .footer-row { flex-direction: column; align-items: flex-start; gap: 16px; }
    }
    .f-logo { font-family: var(--clash); font-size: 1.125rem; font-weight: 700; color: var(--gold); letter-spacing: 0.02em; }
    .f-tag  { font-family: var(--mono); font-size: 0.5625rem; letter-spacing: 0.08em; text-transform: uppercase; color: var(--dim); margin-top: 4px; }
    .f-links { display: flex; gap: 20px; list-style: none; flex-wrap: wrap; }
    .f-links a {
      font-family: var(--mono);
      font-size: 0.5625rem; letter-spacing: 0.08em; text-transform: uppercase;
      color: var(--dim); transition: color 0.2s;
      /* 터치 영역 확보 */
      display: inline-block; padding: 8px 0;
    }
    .f-links a:hover { color: var(--gray); }
    .f-copy { font-family: var(--mono); font-size: 0.5625rem; letter-spacing: 0.06em; color: var(--dim); }

    /* ═══════════════════════════════════
       KEYFRAMES
    ═══════════════════════════════════ */
    @keyframes fadeUp {
      from { opacity:0; transform:translateY(16px); }
      to   { opacity:1; transform:none; }
    }

    /* ═══════════════════════════════════
       REDUCED MOTION
    ═══════════════════════════════════ */
    @media (prefers-reduced-motion: reduce) {
      *, *::before, *::after {
        animation-duration: 0.01ms !important;
        transition-duration: 0.01ms !important;
      }
    }
  </style>
</head>
